#!/usr/bin/env bash
set -euo pipefail

SELF_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
SELF_DIR="$(cd -- "$(dirname -- "${SELF_PATH}")" && pwd)"
ROOT_DIR="$(cd -- "${SELF_DIR}/.." && pwd)"
TOOL_PATH="/usr/local/share/swarm/libexec/swarmsetup"

if [[ ! -x "${TOOL_PATH}" ]]; then
  echo "installed swarmsetup launcher missing at ${TOOL_PATH}" >&2
  echo "manual fix: run ${ROOT_DIR}/scripts/rebuild.sh from a source checkout or rerun install.sh" >&2
  exit 1
fi

exec "${TOOL_PATH}" "$@"
